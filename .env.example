# Copy to .env and set values. API_KEY and VITE_API_KEY must match.

API_KEY=change-me
VITE_API_KEY=change-me

# Default environment tag for POST /api/events when JSON omits "environment"
# (production | staging | development; aliases prod, stg, dev)
METRICS_ENVIRONMENT=development

# Optional: Supabase (cloud) for GET /api/loads — takes precedence over DATABASE_URL
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: Postgres URL for GET /api/loads (e.g. docker-compose.full.yml sets this automatically)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres

# docker-compose.full.yml only — default password is "postgres"
# POSTGRES_PASSWORD=postgres

