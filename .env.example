# Server (Express)
API_KEY=change-me-to-a-long-random-string
PORT=3001
# Optional: persist events JSON here (default: ./data/events.json)
# DATA_DIR=/var/lib/carrier-metrics

# Vite (browser) — must match API_KEY so the dashboard can call GET /api/summary
VITE_API_KEY=change-me-to-a-long-random-string

# --- docker-compose.prod.yml (Caddy + Let’s Encrypt) ---
# Public hostname only (no https://), DNS must point to the server before first start.
METRICS_DOMAIN=metrics.example.com
# Email for ACME (Let’s Encrypt) registration and expiry notices
ACME_EMAIL=you@example.com
